[Unit]
Description=Posiadane filamenty - magazyn filamentow 3D
After=network.target

[Service]
# Zmien User i sciezki jesli trzeba (domyslnie typowy uzytkownik Raspberry Pi).
User=pi
WorkingDirectory=/home/pi/tunia
ExecStart=/home/pi/tunia/.venv/bin/waitress-serve --host=0.0.0.0 --port=5000 app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
